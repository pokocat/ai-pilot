{
  "name": "junshi-app",
  "version": "0.1.6",
  "private": true,
  "description": "军师 · AI 商业军师 — 移动端（Taro 跨端：微信小程序 + H5）",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build:h5:server": "TARO_APP_MODE=server taro build --type h5",
    "dev:h5:server": "TARO_APP_MODE=server taro build --type h5 --watch",
    "build:weapp:server": "TARO_APP_MODE=server TARO_APP_API=https://wxapi.aibuzz.cn/api taro build --type weapp",
    "upload:weapp": "node scripts/weapp-upload.mjs",
    "serve:h5": "node scripts/serve-h5.mjs"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "3.6.34",
    "@tarojs/helper": "3.6.34",
    "@tarojs/plugin-framework-react": "3.6.34",
    "@tarojs/plugin-platform-h5": "3.6.34",
    "@tarojs/plugin-platform-weapp": "3.6.34",
    "@tarojs/react": "3.6.34",
    "@tarojs/runtime": "3.6.34",
    "@tarojs/shared": "3.6.34",
    "@tarojs/taro": "3.6.34",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@tarojs/cli": "3.6.34",
    "@tarojs/webpack5-runner": "3.6.34",
    "@types/react": "^18.2.0",
    "@types/webpack-env": "^1.18.0",
    "babel-preset-taro": "3.6.34",
    "miniprogram-automator": "^0.12.1",
    "miniprogram-ci": "^2.1.31",
    "postcss": "^8.4.0",
    "sass": "^1.69.0",
    "typescript": "^5.4.0",
    "webpack": "5.91.0"
  }
}
