// 军师 · AI 商业军师 — 数据模型
// 对齐《投产开发指导》§3。所有业务表均含 tenantId 做行级隔离。
//
// 生产环境：memory.embedding 应使用 pgvector（vector 类型）做向量检索；
// 本地/演示环境无 pgvector 扩展，这里以 Json（float[]）存储，检索退化为内存余弦相似度。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// WO-07：用户级 journey 状态机（stage + 关键事件时间戳）。diagRound 仍以 StrategicProfile 为真源，派生时读入。
model UserJourney {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String    @unique
  stage          String    @default("new") // new→scanned→diagnosing→plan_ready→executing→reviewing（plan_ready 瞬时）
  quickScanAt    DateTime?
  planAcceptedAt DateTime?
  firstReviewAt  DateTime?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@index([tenantId])
  @@map("user_journey")
}

/// WO-12：处方 = 军师在方案里开出的「问题→打法→工具」三元组，带完整转化状态机。工具白名单在服务端，LLM 只能点菜。
model Prescription {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  casefileId    String?
  deliverableId String?
  orderId       String?
  problem       String    @db.Text
  playbook      String    @db.Text
  toolKey       String
  toolType      String    @default("agent") // agent | external
  externalUrl   String?
  status        String    @default("proposed") // proposed→seen→clicked→activated→used→verified | dismissed
  proposedAt    DateTime  @default(now())
  seenAt        DateTime?
  clickedAt     DateTime?
  activatedAt   DateTime?
  firstUsedAt   DateTime?
  outcomeJson   Json?
  dismissedAt   DateTime?
  followupAt    DateTime? // WO-14：activated 满 7 天由 scheduler 打标一次（周复盘要效果话术只点已打标处方）
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([tenantId])
  @@map("prescription")
}

/// WO-13：品牌资产包——档案 → IP 人设/话术/视觉调性，作为数字人/短剧等生态产品的开箱预填输入。
model BrandKit {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String    @unique
  personaJson Json // { name, tagline, tone, story, doNots[] }
  voiceJson   Json // { hooks[], openers[], ctas[], taboos[] }
  themeJson   Json // { keywords[], colorHint, styleRefs[] }
  version     Int       @default(1)
  generatedAt DateTime  @default(now())
  approvedAt  DateTime? // 用户确认过才可被生态产品读取

  @@index([tenantId])
  @@map("brand_kit")
}

/// WO-05：功能开关（命理等模块一键降级）。id = flag key，如 'fortune'。全局资产，无 tenantId。
model FeatureFlag {
  id        String   @id
  enabled   Boolean  @default(true)
  payload   Json? // 预留分级参数
  updatedAt DateTime @updatedAt

  @@map("feature_flag")
}

/// WO-08：行业基准库（内容资产，运营维护）。分位数 p25/p50/p75；宁缺勿假——p50 空的行不注入。
model IndustryBenchmark {
  id          String   @id @default(cuid())
  industry    String // 与 survey 行业口径一致
  revenueBand String   @default("*") // 营收段，'*'=不分段
  metricKey   String // 'repurchase_rate' | 'cac' | ...
  metricName  String // 展示名「复购率」
  unit        String // '%' | '元' | '天'
  p25         Float?
  p50         Float?
  p75         Float?
  note        String? // 口径说明
  source      String? // 数据来源
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@unique([industry, revenueBand, metricKey])
  @@map("industry_benchmark")
}

/// WO-10：结构化经营周报（字段与 IndustryBenchmark.metricKey 同口径——报什么就能对比什么）。
model BizMetricWeekly {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  weekStart   String // YYYY-MM-DD（周一）
  metricsJson Json // { metricKey: number }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("biz_metric_weekly")
}

/// 租户（企业）
model Tenant {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  stage     String?
  createdAt DateTime @default(now())

  users        User[]
  profiles     Profile[]
  sessions     Session[]
  deliverables Deliverable[]
  memories     Memory[]
  credits      CreditLedger[]
  audits       AuditLog[]
  projects     Project[]
  reports      ReportDoc[]
  knowledge    KnowledgeItem[]
  tokenUsages  TokenUsage[]
  tokenWallets TokenWallet[]

  @@map("tenant")
}

/// 用户（企业成员）
model User {
  id              String    @id @default(cuid())
  tenantId        String
  phone           String    @unique
  wechatOpenId    String?   @unique
  wechatUnionId   String?   @unique
  name            String
  avatarUrl       String? // 头像：微信「头像昵称填写能力」选取后上传 OSS 的公网链接；可在设置中修改
  role            String    @default("owner") // owner | member | admin
  benmingColor    String    @default("green") // 本命色：首登可改，墨绿默认（设计稿主色）
  planId          String?
  // 套餐有效期（D1/D2）：购买/续费/升级时写入；status 由 now vs planExpiresAt 派生（不存字段）。
  // planActivatedAt = 当前付费套餐激活时刻，兼作月度额度重置的「订阅锚点」（按激活日的 day-of-month 每月重置）。
  // planExpiresAt   = 绝对 UTC 到期时间；null = 不到期（免费层 / 企业版私有化 / 历史 grandfather 用户）。
  planActivatedAt DateTime?
  planExpiresAt   DateTime?
  inviteCode      String?   @unique // V7-13：邀请码（首次读取惰性生成 = "JS"+4 位 base32，跨用户唯一）
  createdAt       DateTime  @default(now())
  wechatLinkedAt  DateTime?

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  plan                Plan?                   @relation(fields: [planId], references: [id])
  sessions            Session[]
  deliverables        Deliverable[]
  memories            Memory[]
  credits             CreditLedger[]
  agents              UserAgent[] // 已开通的智能体（赠送 / 购买 / 后台开通）
  tokenUsages         TokenUsage[]
  tokenWallet         TokenWallet?
  wechatSubscriptions WechatSubscription[]
  wechatNotifications WechatNotificationLog[]

  @@map("app_user")
}

/// 运营后台管理员账户（与小程序用户分离）。主密钥 ADMIN_TOKEN 首次引导初始化首个 owner 账户，
/// 之后 owner 可在后台新增 operator 账户（多运营协作）；主密钥保留为应急/找回通道。
model AdminAccount {
  id             String              @id @default(cuid())
  username       String              @unique
  passwordHash   String // scrypt$salt$hash（Node 内置 crypto，无外部依赖）
  role           String              @default("operator") // owner 超管（管账户/见全部 agent）| operator 普通运营（仅负责的 agent）
  disabledAt     DateTime? // 停用：保留账户与审计，禁止登录与操作
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lastLoginAt    DateTime?
  sessions       AdminSession[]
  collaborations AgentCollaborator[]

  @@map("admin_account")
}

/// 运营后台登录会话：账号密码登录后下发的不透明 token（仍走 x-admin-token 头）。
model AdminSession {
  token     String   @id // 随机不透明串
  accountId String
  createdAt DateTime @default(now())
  expiresAt DateTime

  account AdminAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
  @@map("admin_session")
}

/// 企业档案（首登 30 秒建档 + 可选补充资料）
model Profile {
  id        String   @id @default(cuid())
  tenantId  String
  industry  String?
  stage     String?
  pain      String?
  extraJson Json?
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("profile")
}

/// 智能体（顾问 / 创作）—— 运营后台可配置
model Agent {
  id             String  @id @default(cuid())
  key            String  @unique // strat / growth / ...
  name           String
  role           String
  icon           String
  type           String // advisory | creative | general | custom
  gift           Boolean @default(true) // 注册即赠送（=billing free）；仅用于前台「赠送」标记
  billing        String  @default("free") // free 免费 | unlock 一次性解锁 | metered 按次计费
  price          Int     @default(0) // 价格（单位：算力次数）。unlock=解锁一次性消耗；metered=每次产出消耗
  billingRatio   Float   @default(1) // 文本类 token 计费比例：扣额=ceil(真实token×ratio)。如标准 1.0、Dify 2.0
  meterUnit      String  @default("text") // text=扣月度 token 额度 | image=按张扣钻石(点)
  enabled        Boolean @default(true)
  greet          String  @db.Text
  chipsJson      Json // [["target","战略体检"], ...]
  memText        String  @db.Text // 记忆条文案
  learnText      String // “记忆已更新” 等
  systemPrompt   String  @db.Text
  deliverableKey String? // 关联的产出模板 key（如「战略体检」）
  memoryConfig   Json // { longTerm, autoLearn, intensity, retentionDays, sources[] }

  // —— 运行时接入方式（运营后台可为每个智能体单独配置）——
  // inherit 跟随全局模型 | openai 自定义 OpenAI 兼容端点 | dify 绑定 Dify 应用
  providerMode   String  @default("inherit")
  // 自定义 OpenAI 兼容端点（providerMode=openai 时生效）
  apiBaseUrl     String? // 如 https://api.deepseek.com/v1
  apiModel       String? // 如 deepseek-chat
  apiTemperature Float? // P2-7：per-agent 温度（providerMode=openai；留空=跟随全局）
  apiKey         String? @db.Text
  // Dify 应用（providerMode=dify 时生效）。chat-messages 接口
  difyBaseUrl    String? // 如 http://ai.aibuzz.cn/v1
  difyApiKey     String? @db.Text // 每个 Dify 应用专属 key
  difyInputs     Json? // { difyVarName: "{企业档案}" }：本地上下文按占位符映射成 Dify inputs
  // 自建技能（工具调用，providerMode=openai 时生效）：{ enabled, tools:[内置工具名], customTools? }
  skillsConfig   Json?

  // —— 版本化（P0）：本行 = 运营正在编辑的「工作草稿」；C 端实际读 publishedVersionId 指向的不可变快照 ——
  publishedVersionId String? // → AgentVersion.id（C 端使用的已发布版本）；null=尚未发布，运行时回退本行草稿
  draftDirty         Boolean @default(false) // 草稿与已发布版本是否有差异（编辑即置 true，发布后清零）

  sort      Int      @default(0)
  updatedAt DateTime @updatedAt

  sessions      Session[]
  deliverables  Deliverable[]
  memories      Memory[]
  reportDocs    ReportDoc[]
  owners        UserAgent[]
  versions      AgentVersion[]
  collaborators AgentCollaborator[]

  @@map("agent")
}

/// 智能体版本快照（不可变）：发布即冻结当时的「行为 + 定价 + 接入」。C 端按 Agent.publishedVersionId 只读此表。
/// 调教闭环：运营改 Agent 草稿 → 沙盒试 → 满意后 snapshot 成新 version → 指针指向它。回滚 = 指针重指旧 version。
model AgentVersion {
  id            String  @id @default(cuid())
  agentKey      String
  version       Int // 每个 agent 内自增 1,2,3…
  status        String  @default("draft") // draft 草稿快照 | published 已发布 | archived 历史
  label         String? // 运营起的版本名，如「v3 强化择时方法论」
  changeSummary String? @db.Text // 相对上一版的字段级变更摘要
  contentHash   String // sha256(canonical(快照))，去重 + 漂移检测

  // —— 冻结的行为快照（对齐 Agent 上的可调字段）——
  systemPrompt   String  @db.Text
  memoryConfig   Json
  skillsConfig   Json?
  greet          String  @db.Text
  deliverableKey String?
  // P1-A5：面向用户的行为内容也随版本冻结（旧版本为 null → 消费方回退 Agent 行，无回归）
  chipsJson      Json?
  memText        String? @db.Text
  learnText      String?
  // 定价随版本走（调教越好→倍率越高→卖越贵）
  billing        String  @default("free") // free | unlock | metered
  price          Int     @default(0)
  billingRatio   Float   @default(1) // token 消耗倍率：扣额=ceil(真实token×ratio)
  meterUnit      String  @default("text") // text=扣 token 额度 | image=按张扣钻石
  // 接入方式快照
  providerMode   String  @default("inherit")
  apiBaseUrl     String?
  apiModel       String?
  apiTemperature Float? // P2-7：per-agent 温度（随版本冻结）
  apiKey         String? @db.Text
  difyBaseUrl    String?
  difyApiKey     String? @db.Text
  difyInputs     Json?

  createdBy   String? // AdminAccount.id（哪个运营快照/发布的；不挂硬关系，便于停用账户后仍可溯源）
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  agent Agent @relation(fields: [agentKey], references: [key], onDelete: Cascade)

  @@unique([agentKey, version])
  @@index([agentKey, status])
  @@map("agent_version")
}

/// 智能体协作者（多运营）：哪个后台账户能编辑/查看哪个 agent。owner 角色账户隐式拥有全部 agent。
model AgentCollaborator {
  id        String   @id @default(cuid())
  agentKey  String
  accountId String
  role      String   @default("editor") // editor 可编辑/发布 | viewer 只读
  createdAt DateTime @default(now())

  agent   Agent        @relation(fields: [agentKey], references: [key], onDelete: Cascade)
  account AdminAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([agentKey, accountId])
  @@index([accountId])
  @@map("agent_collaborator")
}

/// 用户已开通的智能体（行级权益）。free/metered 智能体无需此记录即可使用；
/// unlock（一次性解锁）智能体需有此记录才可对话产出。
model UserAgent {
  id        String    @id @default(cuid())
  userId    String
  agentKey  String
  source    String    @default("purchase") // gift 注册赠送 | purchase 算力解锁 | admin_grant 后台开通
  pricePaid Int       @default(0) // 解锁时消耗的算力次数（admin_grant=0）
  createdAt DateTime  @default(now())
  expiresAt DateTime? // 预留：限时开通

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentKey], references: [key], onDelete: Cascade)

  @@unique([userId, agentKey])
  @@index([userId])
  @@map("user_agent")
}

/// 会话（按 用户×智能体 隔离，可回溯；可归属项目）
model Session {
  id                 String    @id @default(cuid())
  tenantId           String
  userId             String
  agentKey           String
  projectId          String? // 归属项目（散落会话为 null）
  title              String    @default("新对话")
  difyConversationId String? // Dify 应用多轮上下文 id（providerMode=dify 时由 Dify 返回并回写）
  mode               String? // 会话模式（M3 PR-11 粘性）：'review:week' | 'urgent' | 'timing' | …；null=strategy
  lastReadAt         DateTime? // 未读判定：最后一条 AI 回复晚于此即未读；打开会话时置 now
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  agent        Agent         @relation(fields: [agentKey], references: [key])
  project      Project?      @relation(fields: [projectId], references: [id])
  messages     Message[]
  deliverables Deliverable[]

  @@index([userId, agentKey])
  @@index([projectId])
  @@map("session")
}

/// 消息
model Message {
  id          String   @id @default(cuid())
  sessionId   String
  role        String // user | assistant | report
  contentJson Json // { text } | { key, ...deliverable } 等
  refsJson    Json? // MessageRef[]：本条消息引用的 项目/报告/知识/记忆
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("message")
}

/// 成果（方案库）。存库即桥接到版本化报告（reportId 指向 ReportDoc）。
model Deliverable {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  sessionId   String?
  projectId   String?
  reportId    String? // 桥接：该成果对应的版本化报告
  agentKey    String
  title       String
  type        String // 成果类型 = deliverableKey
  contentJson Json // §4.2 结构化成果
  pdfUrl      String?
  status      String   @default("ready") // generating | ready | failed
  createdAt   DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])
  agent   Agent    @relation(fields: [agentKey], references: [key])

  @@index([userId])
  @@map("deliverable")
}

/// 长期记忆（按 用户×智能体 隔离；可归属项目，可语义召回）
model Memory {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  agentKey  String
  projectId String? // 归属项目（跨智能体共享时可空）
  kind      String // fact | preference | feedback
  category  String? // 军师记忆库六类：founder|company|status|vision|strategy|rapport（旧行为 null）
  text      String    @db.Text
  embedding Json? // float[]（生产用 pgvector；本地降级内存余弦）
  weight    Float     @default(1.0)
  source    String // conversation | document | deliverable_feedback
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  agent   Agent    @relation(fields: [agentKey], references: [key])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId, agentKey])
  @@index([userId, category]) // 记忆库按类分组读取
  @@index([projectId])
  @@map("memory")
}

/// 项目（企业事务主线）—— 串起 会话 / 报告 / 知识 / 记忆，租户级
model Project {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String // 创建者
  name      String
  slug      String // 归一化名（租户内唯一）
  icon      String   @default("layers")
  summary   String?  @db.Text // LLM 维护的项目滚动摘要（被引用时注入上下文）
  status    String   @default("active") // active | archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  sessions  Session[]
  reports   ReportDoc[]
  knowledge KnowledgeItem[]
  memories  Memory[]

  @@unique([tenantId, slug])
  @@index([tenantId, userId])
  @@map("project")
}

/// 逻辑报告（按「报告名(slug)」唯一）—— 版本管理的锚点
model ReportDoc {
  id             String   @id @default(cuid())
  tenantId       String
  projectId      String?
  userId         String
  title          String
  slug           String // 报告名归一化 → 版本管理 key
  type           String // 战略体检 / 增长方案 / …
  agentKey       String?
  currentVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  project  Project?        @relation(fields: [projectId], references: [id])
  agent    Agent?          @relation(fields: [agentKey], references: [key])
  versions ReportVersion[]

  @@unique([tenantId, slug])
  @@index([tenantId, userId])
  @@index([projectId])
  @@map("report_doc")
}

/// 不可变版本快照（内容寻址去重 + 变更摘要）
model ReportVersion {
  id            String   @id @default(cuid())
  reportId      String
  version       Int
  title         String
  contentJson   Json // Deliverable 结构
  contentHash   String // sha256(canonical(content)) → 去重/校验
  changeSummary String?  @db.Text // 相对上一版的变更摘要
  authorKind    String   @default("agent") // agent | user
  sessionId     String? // 来自哪次对话
  createdAt     DateTime @default(now())

  report ReportDoc @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
  @@index([reportId])
  @@map("report_version")
}

/// 知识库条目（租户级，可挂项目）—— 统一承载：对话提炼 / 上传文档 / 报告引用
model KnowledgeItem {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String?
  userId      String
  kind        String // insight | document | decision | todo | report_ref
  title       String?
  text        String   @db.Text // 规范化文本（用于检索/注入）
  sourceType  String // conversation | upload | deliverable | manual
  sourceId    String? // sessionId / reportVersionId / uploadId
  tagsJson    Json     @default("[]")
  // —— V7-06 三段式资料整理管道（加法，存量数据零迁移）——
  stage       String   @default("confirmed") // staging 待整理（不进检索）| optimized 已优化（待确认）| confirmed 知识库（已嵌入）
  bizCategory String? // AI 粗分业务类目 key（见 data/bizCategories.ts）
  batchId     String? // 同批上传标识（整理动作以批为单位）
  dupOfId     String? // 规则去重命中的原件 id（同名+同大小）
  // —— 文档上传管线（sourceType=upload）：解析状态 + 原件元信息 ——
  status      String   @default("ready") // ready | parsing | embedding | failed（非上传项一律 ready）
  fileName    String? // 原始文件名
  fileType    String? // mime 或扩展名（pdf/docx/xlsx/md/txt）
  fileSize    Int? // 字节
  fileKey     String? // OSS 对象 key（原件，预览/重解析用；不可猜 cuid 前缀）
  error       String?  @db.Text // 解析/嵌入失败原因
  // WO-09 经营体检：财务表结构化抽取 + 纯代码派生指标的落库快照（{ financials, metrics }）。
  // 报告正文数字一律以此为准（数字铁律）；非财务/未分析条目为 null。db push 纯加法。
  analysisJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  project Project?         @relation(fields: [projectId], references: [id])
  chunks  KnowledgeChunk[]

  @@index([tenantId, projectId])
  @@index([tenantId, userId])
  @@index([tenantId, userId, stage]) // V7-06：按管道阶段取用
  @@map("knowledge_item")
}

/// 知识切片 + 向量（生产用 pgvector vector 类型 + HNSW；本地降级 Json + 内存余弦）
model KnowledgeChunk {
  id        String   @id @default(cuid())
  itemId    String
  tenantId  String
  ord       Int
  text      String   @db.Text
  embedding Json? // float[]
  createdAt DateTime @default(now())

  item KnowledgeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([tenantId])
  @@map("knowledge_chunk")
}

/// 每日献策
model Saying {
  id         String   @id @default(cuid())
  text       String   @db.Text
  enabled    Boolean  @default(true)
  sort       Int      @default(0)
  pushedDate String? // YYYY-MM-DD 最近推送日期
  createdAt  DateTime @default(now())

  @@map("saying")
}

/// 建档问卷（运营可配）
model SurveyQuestion {
  id          String  @id @default(cuid())
  key         String  @unique // industry | stage | pain
  title       String
  optionsJson Json // string[]
  sort        Int     @default(0)
  enabled     Boolean @default(true)

  @@map("survey_question")
}

/// 套餐与算力
model Plan {
  id                 String  @id @default(cuid())
  name               String
  price              Int // 分
  period             String // month | year
  creditsPerMonth    Int // 钻石(点)：每月赠送，用于一次性解锁 + 图片按张
  tokenQuotaPerMonth Int     @default(0) // 月度 token 额度（文本产出消耗池），-1=不限量
  agentCount         Int
  featuresJson       Json
  highlighted        Boolean @default(false)
  sort               Int     @default(0)

  users User[]

  @@map("plan")
}

/// 支付订单（套餐购买的状态机 + 幂等入账锚点）。
/// 状态流：created → paid（回调验签通过）→ applied（权益已发放，幂等终态）；或 closed/failed。
/// 幂等：appliedAt 为「恰好一次」入账的原子锚点（条件更新抢占，防重复回调/并发双发权益）。
model PaymentOrder {
  id            String    @id @default(cuid())
  outTradeNo    String    @unique // 商户订单号（我们生成，提交给微信）
  tenantId      String
  userId        String
  planId        String    @default("") // 套餐订单挂 planId；SKU 订单为空串
  skuKey        String? // V7-12：单次付费商品订单挂 SKU key（与 planId 二选一）
  amount        Int // 应付金额（分）
  currency      String    @default("CNY")
  provider      String    @default("wechat") // wechat | mock（未配支付时的演示通道）
  status        String    @default("created") // created | paid | applied | failed | closed | refunded
  prepayId      String? // 微信预支付交易会话标识
  transactionId String? // 微信支付订单号（回调返回）
  paidAt        DateTime?
  appliedAt     DateTime? // 权益发放完成时间 = 幂等终态锚点
  rawNotifyJson Json? // 回调解密后的原文（排查用）
  attrSource    String? // D-1 开通来源归因（下单时从请求体带入，回调发放时落 ActivationEvent）：prescription | catalog | market
  attrRefId     String? // attrSource=prescription 时的 prescriptionId
  snapshotJson  Json? // 下单时的套餐/SKU 条款快照（P1：发放以此为准，防「下单后改价/删配置」漂移；无快照的历史单回退读当前配置）
  refundId      String? // 微信退款单号（out_refund_no）
  refundedAt    DateTime? // 退款完成时间 = 退款幂等终态锚点
  refundReason  String? // 退款原因（运营填写，进审计）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payment_order")
}

/// 算力账户流水
model CreditLedger {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  delta     Int // 正充值 / 负消耗
  reason    String
  balance   Int
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("credit_ledger")
}

/// 月度 Token 额度账户（文本产出消耗池，区别于钻石 CreditLedger）。每用户单行，惰性按月重置。
model TokenWallet {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String   @unique
  quota     Int      @default(0) // 本月授予总额度；<0=不限量
  balance   Int      @default(0) // 本月剩余（可透支为负=已耗尽）；不限量时忽略
  periodKey String   @default("") // YYYY-MM，惰性重置锚点
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("token_wallet")
}

/// Token 用量流水（P1：旁路统计，不参与按次扣费）。一次真实模型调用记一行；mock / 缓存命中不记。
model TokenUsage {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String?
  sessionId    String? // 溯源到会话
  agentKey     String?
  kind         String // deliverable | chat（v1 仅计这两条主路径）
  provider     String // claude | openai
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cachedInput  Int      @default(0) // 命中提示缓存的输入 token（计价更低）
  totalTokens  Int      @default(0) // = input + output，便于 SUM
  costMicros   Int      @default(0) // 估算成本，单位 1e-6 元（微元），整数防浮点漂移
  creditCost   Int      @default(0) // 本次扣的点；P1 恒为 0，P2 接按 token 扣费时填实际
  createdAt    DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@map("token_usage")
}

/// LLM 调用诊断 trace（可观测）。与 token_usage 分表：trace 要记 mock/0token/错误，不污染计费口径。
/// 不挂关系，纯写入 + 索引查询。promptText/responseText 仅在 LLM_TRACE_CAPTURE_TEXT=true 时截断存储。
model LlmTrace {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String?
  sessionId    String?
  agentKey     String?
  versionId    String? // P1-A1：产出所用的已发布版本(AgentVersion.id)，把质量回归归因到具体版本
  kind         String // deliverable | chat
  provider     String // openai | claude | mock | dify
  model        String
  status       String // ok | error
  errorMessage String?  @db.Text
  latencyMs    Int      @default(0)
  toolCalls    Int      @default(0) // 启用技能时的工具调用次数
  iterations   Int      @default(0) // 工具循环轮数
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cachedInput  Int      @default(0) // 命中提示缓存的输入 token（按 ~1/10 计费；provider 不报则 0）
  totalTokens  Int      @default(0)
  promptText   String?  @db.Text
  responseText String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([agentKey, createdAt])
  @@index([status, createdAt])
  @@map("llm_trace")
}

// P2-10：单工具调用日志，用于 per-tool 成功率/错误率/延迟观测（在工具循环里 fire-and-forget 写入）。
model ToolCallLog {
  id        String   @id @default(cuid())
  agentKey  String?
  tool      String
  ok        Boolean
  ms        Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tool, createdAt])
  @@index([agentKey, createdAt])
  @@map("tool_call_log")
}

/// 服务端渲染的可分享报告 HTML 页（凭不可猜 id 公开访问，发朋友圈用；只含报告正文，不含敏感数据）。
model ReportHtml {
  id        String   @id @default(cuid())
  tenantId  String?
  title     String
  html      String   @db.Text
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("report_html")
}

/// 运营自助技能库：自定义 HTTP 工具。agent 通过 skillsConfig.tools 按 key 勾选启用。
model SkillTool {
  id           String   @id @default(cuid())
  key          String   @unique // 模型看到的函数名（英文 slug，如 query_order）
  name         String // 展示名（中文）
  description  String   @db.Text // 给模型：这个工具做什么、何时调用
  inputSchema  Json // JSON Schema：参数定义
  httpMethod   String   @default("POST") // GET | POST
  httpUrl      String   @db.Text
  headersJson  Json? // 静态请求头（含鉴权密文）——后台读取时脱敏
  argsLocation String   @default("body") // body | query：工具参数放 JSON body 还是 query string
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("skill_tool")
}

/// 评测集（黄金测试集）：某 agent 的一组固定测试用例，调教后反复跑，用分数客观衡量「调教得多好」。
model EvalSet {
  id        String     @id @default(cuid())
  agentKey  String
  name      String
  createdBy String? // AdminAccount.id
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cases     EvalCase[]

  @@index([agentKey])
  @@map("eval_set")
}

/// 评测用例：一条输入（+可选的模拟客户上下文）+ 给评委的评分标准。
model EvalCase {
  id          String  @id @default(cuid())
  setId       String
  input       String  @db.Text // 模拟 C 端用户消息
  contextJson Json? // 可选：模拟 profile / 引用资料，注入沙盒上下文
  rubric      String? @db.Text // 给 LLM 评委的评分标准（这条好答案长什么样）
  weight      Float   @default(1)
  sort        Int     @default(0)

  set EvalSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@map("eval_case")
}

/// 评测运行：把某个版本（已发布版本 id 或 "draft"）跑过整套用例，LLM 评委逐条打分，汇总加权总分。
model EvalRun {
  id          String           @id @default(cuid())
  agentKey    String
  setId       String
  targetRef   String // 被测对象：AgentVersion.id | "draft"
  targetLabel String? // 展示用，如「草稿」「v3」
  status      String           @default("running") // running | done | error
  score       Float? // 0..10 加权平均
  judgeModel  String?
  note        String?          @db.Text // 错误信息或汇总评语
  createdBy   String?
  createdAt   DateTime         @default(now())
  results     EvalCaseResult[]

  @@index([agentKey, createdAt])
  @@map("eval_run")
}

/// 评测单条结果：该用例在被测版本上的产出 + 评委打分。
model EvalCaseResult {
  id           String   @id @default(cuid())
  runId        String
  caseId       String
  input        String   @db.Text // 快照用例输入（用例可能后续被改）
  output       String   @db.Text // 被测版本的产出
  judgeScore   Float? // 0..10
  judgeNote    String?  @db.Text // 评委理由
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  latencyMs    Int      @default(0)
  createdAt    DateTime @default(now())

  run EvalRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("eval_case_result")
}

/// 时序知识图谱 · 实体节点（Graphiti 式）。租户级，按归一名+类型去重。
model GraphEntity {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String?
  name      String // 展示名
  normName  String // 归一名（小写去空白）用于去重
  type      String   @default("other") // person | org | product | concept | other
  createdAt DateTime @default(now())

  subjectOf GraphRelation[] @relation("subject")
  objectOf  GraphRelation[] @relation("object")

  @@unique([tenantId, normName, type])
  @@index([tenantId, projectId])
  @@map("graph_entity")
}

/// 时序知识图谱 · 关系边。带有效时间窗（validFrom/validTo）以回答「X 时谁负责 Y」类时序问题。
/// 新事实使旧的同主语+谓词关系「失效」（置 validTo / invalidatedAt），保留历史可回溯。
model GraphRelation {
  id            String    @id @default(cuid())
  tenantId      String
  projectId     String?
  subjectId     String
  predicate     String // 谓词，如「负责」「就职于」「持有」
  objectId      String
  validFrom     DateTime  @default(now()) // 该事实生效起点
  validTo       DateTime? // 失效终点（null=至今有效）
  invalidatedAt DateTime? // 被新事实推翻的时刻（软失效，区别于自然到期）
  source        String    @default("conversation") // conversation | document | manual
  sourceId      String?
  confidence    Float     @default(1.0)
  createdAt     DateTime  @default(now())

  subject GraphEntity @relation("subject", fields: [subjectId], references: [id], onDelete: Cascade)
  object  GraphEntity @relation("object", fields: [objectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([subjectId])
  @@index([objectId])
  @@map("graph_relation")
}

/// 审计日志
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  payloadJson Json?
  createdAt   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("audit_log")
}

/// 内容审核日志
model ModerationLog {
  id         String   @id @default(cuid())
  refType    String // input | output
  refId      String?
  tenantId   String? // P1-B5：用户/会话/租户关联，使被拦事件可追溯（此前 write-only 黑洞）
  userId     String?
  sessionId  String?
  verdict    String // pass | block
  detailJson Json?
  createdAt  DateTime @default(now())

  @@index([verdict, createdAt])
  @@map("moderation_log")
}

/// 大模型配置（单例，记录「当前生效」模型 = 运行时实际读取的解析配置）。
/// 运营后台可在已添加的 AiModel 之间快速切换：切换=把目标 AiModel 拷进本行 + 记 activeModelId。
/// getAiConfig 仍只读本行，运行时路径不变。生产应加密存储 apiKey / 接密管。
model AiSetting {
  id             String  @id @default("default")
  provider       String  @default("openai") // mock | claude | openai(兼容 Agnes/DeepSeek/Qwen…)
  label          String  @default("Agnes 2.0 Flash")
  baseUrl        String  @default("https://apihub.agnes-ai.com/v1")
  model          String  @default("agnes-2.0-flash")
  apiKey         String  @default("") @db.Text
  embeddingModel String  @default("")
  temperature    Float   @default(0.7)
  activeModelId  String? // 指向当前生效的 AiModel.id（后台高亮用，运行时不依赖）

  // 向量嵌入接入（开关 + 可独立配凭证；留空回退对话模型的 baseUrl/key）。
  embeddingEnabled Boolean @default(false)
  embeddingBaseUrl String  @default("")
  embeddingApiKey  String  @default("") @db.Text

  // 重排（rerank）接入：开启后 hybridSearch 融合打分再调 rerank API 重排 TopN。
  rerankEnabled Boolean @default(false)
  rerankModel   String  @default("")
  rerankBaseUrl String  @default("")
  rerankApiKey  String  @default("") @db.Text

  updatedAt DateTime @updatedAt

  @@map("ai_setting")
}

/// 已添加的模型接入点（运营可添加多个，快速切换其一生效）。
/// 来源三种：内置接入商预设（preset 记其 id）/ 自定义通用兼容协议 / 完全自主定义。
model AiModel {
  id               String   @id @default(cuid())
  provider         String   @default("openai") // mock | claude | openai
  label            String // 展示名，如「Agnes 2.0 Flash」
  baseUrl          String   @default("")
  model            String   @default("")
  apiKey           String   @default("") @db.Text
  embeddingModel   String   @default("")
  temperature      Float    @default(0.7)
  preset           String? // 来源内置接入商 id（自定义/自主定义则空）
  // 内部成本核算单价（元 / 1M token）。0=未配置 → 回退内置价表/兜底。Token 用量看板按此估算总成本。
  priceInput       Float    @default(0)
  priceOutput      Float    @default(0)
  priceCachedInput Float    @default(0) // 命中缓存输入价；0=按 priceInput 计
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("ai_model")
}

/// 短信验证码（注册/登录前发放，先于账号存在，故按 phone 关联而非 userId）。
/// 安全：明文验证码不落库，仅存 sha256(phone:code)；按 phone 限频、限尝试次数、限有效期。
model SmsCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String // sha256(phone:code)，校验时同法比对
  scene      String    @default("login") // login | bind | rebind…
  expiresAt  DateTime
  consumedAt DateTime? // 命中即消费，防重放
  attempts   Int       @default(0) // 错误尝试次数，超限作废
  ip         String? // 发送来源，便于风控/审计
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@map("sms_code")
}

/// 微信小程序订阅消息授权额度。小程序订阅消息默认是一次性授权：
/// 前端每次 requestSubscribeMessage accept，服务端给对应 scene/templateId 增加 1 次可发送额度；
/// 发送成功后扣减，避免把用户拒绝或过期授权误当成长期触达能力。
model WechatSubscription {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  scene      String // review | report
  templateId String
  status     String    @default("accept") // accept | reject | ban | filter
  remaining  Int       @default(0)
  acceptedAt DateTime?
  lastSentAt DateTime?
  updatedAt  DateTime  @updatedAt
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scene, templateId])
  @@index([tenantId, scene])
  @@map("wechat_subscription")
}

/// 微信订阅消息发送日志：记录 sent/failed/skipped，用于低频重要触达排查与幂等。
model WechatNotificationLog {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  scene       String // review | report
  templateId  String?
  title       String
  status      String // sent | failed | skipped
  reason      String?
  payloadJson Json?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, scene, createdAt])
  @@index([scene, status, createdAt])
  @@map("wechat_notification_log")
}

/// 战略案卷（PR-EX 执行闭环落库）：认可方案 → 案卷 → 军令打卡 → 数据回填 → 复盘。
/// 同一用户同时只有一个 active 案卷（V6.0 单主线叙事）；军令/回填按日累积，
/// 后续对齐率、连续复盘天数、看板第一层全部以这里的事件为分母（服务端计数，不让 AI 现编）。
model Casefile {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  title       String
  sourceAgent String   @default("军师") // 认可时的军师名
  judgment    String   @default("") @db.Text // 主判断（来自认可方案首段，战局 hero 读它）
  risksJson   Json // string[]：「现在不能做」风险锁
  goalsJson   Json? // V7-10：目标阶梯 { longTerm?, annual?, quarterly?, weekly?, updatedAt? }
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders  CasefileOrder[]
  metrics CasefileMetric[]

  @@index([tenantId, userId, status])
  @@map("casefile")
}

/// 军令：案卷拆出的每日行动（执行页打卡对象）。aligned 由 AI 拆解时标注
/// 是否对齐主要矛盾（对齐率的分子来源）；手动录入为 null=未标注。
model CasefileOrder {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  casefileId  String
  date        String // YYYY-MM-DD：属于哪一天的军令
  text        String    @db.Text
  fromAgent   String    @default("我") // 来源：军师名 / 我
  tag         String    @default("军令 · 自定") // 类别徽标
  aligned     Boolean? // 是否对齐主要矛盾（null=未标注）
  // V7-05：军令结构化字段（LLM 拆解或启发式缺省填充，全部加法可空）
  ownerName   String? // 负责人（缺省=用户称呼）
  dueAt       String? // 截止标签（18:00 / 今日 / 本周 / 待补）
  etaMinutes  Int? // 预计耗时（分钟）
  sourceQuote String?   @db.Text // 来源引用（方案原文片段）
  stepsJson   Json? // string[]：三步骤（准备/处理/回写）
  metricsJson Json? // { label, value }[]：指标对
  actionType  String? // upload | backfill | review | topics | none：下一步动作类型
  done        Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())

  casefile Casefile @relation(fields: [casefileId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, date])
  @@index([casefileId, date])
  @@map("casefile_order")
}

/// 数据回填：每日经营三数（线索/咨询/成交）。每案卷每天一条（upsert），
/// 是复盘的事实依据与看板第一层数据源。
model CasefileMetric {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  casefileId String
  date       String // YYYY-MM-DD
  leads      Int      @default(0)
  consults   Int      @default(0)
  deals      Int      @default(0)
  savedAt    DateTime @default(now())

  casefile Casefile @relation(fields: [casefileId], references: [id], onDelete: Cascade)

  @@unique([casefileId, date])
  @@index([tenantId, userId, date])
  @@map("casefile_metric")
}

/// 命盘（M1 PR-1 排盘引擎）：确定性排盘结果快照，每用户一张（重排覆盖）。
/// 铁律：所有命理/历法运算由引擎（services/paipan.ts）算好存这里，AI 只做比喻翻译，禁止自算。
/// chartJson 内含 engineVersion，引擎升级后可按版本号批量复算。
model NatalChart {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String   @unique
  engineVersion    String
  gender           String // male | female
  calendar         String // solar | lunar（用户录入用的历法）
  birthDate        String // 录入原值 YYYY-MM-DD（按 calendar 解释）
  birthHour        Int? // 0-23；null = 时辰不确定（三柱排盘 + 近似大运）
  birthMinute      Int?
  birthPlace       String?
  longitude        Float? // 东经；提供则做真太阳时校正（v1 平太阳时）
  trueSolarApplied Boolean  @default(false)
  chartJson        Json // ChartView：四柱十神/格局打法/大运/流月攻守/紫微主星
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@map("natal_chart")
}

/// 战略档案（M1 PR-3 统一状态层）：客户已确认的战略事实，跨会话一等公民。
/// 与 understanding（证据自动推断的摘要）分工：本表只存「用户认可过/亲口确认」的结论，
/// 注入时标注为已确认事实、优先于推断。v1 回写触发点 = 认可方案 + 手动编辑；
/// LLM 逐轮结构化抽取与 M2 决策日志共用同一抽取管道（见 AGENTS §13）。
model StrategicProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String    @unique
  mainContradiction String    @default("") @db.Text // 主要矛盾（一句话）
  positioning       String    @default("") @db.Text // 战略定位
  track             String    @default("") @db.Text // 聚焦赛道
  stage             String    @default("") // 三步走当前阶段/经营阶段
  diagRound         Int       @default(0) // F-5：当前诊断轮次，用户级持久化（换/删会话不清零）
  diagSessionId     String? // 最近一次诊断所在会话（切换不重置轮次）
  dossierJson       Json? // P3：生成即缓存的「完整履历」结构化档案（DossierReport）
  dossierAt         DateTime? // 履历最近生成时间
  forcesJson        Json? // L-6 三势真数据化：{shishi/renshi: {verdict:攻|守|等|撤, note}}（天势走命盘不入库）
  twelveQJson       Json? // 十二问答案沉淀（M3 状态机写入）
  kpiJson           Json? // 核心 KPI 基线（M2 看板写入）
  extraJson         Json? // 前向兼容（叙事线/谶语等 P1 内容）
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  @@index([tenantId])
  @@map("strategic_profile")
}

/// 决策日志（M2 PR-7）：V6.0 §9 决策账本——每条决策带验证标准与验证期，
/// 准确率一律由服务端从状态行统计（禁止 AI 现编）。写入源：认可方案自动记一条 + 手动/AI 工具。
model DecisionLog {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  seq            Int // 用户内序号（决策 #N，展示与引用用）
  scene          String    @default("战略规划") // 战略规划 | 复盘 | 紧急战况 | 手动
  decision       String    @db.Text // 一句话决策
  reasons        Json // string[]：2-3 个关键理由
  tianshiRef     String    @default("") // 天势参考（命理层面的支持/警示，来自命盘数据）
  expected       String    @default("") @db.Text // 预期结果
  verifyStandard String    @default("") @db.Text // 什么数据能证明正确/错误
  verifyByDate   String? // YYYY-MM-DD 预计验证时间（scheduler 到期提醒用）
  status         String    @default("pending") // pending | correct | revise
  verifiedAt     DateTime?
  verifyNote     String    @default("") @db.Text // 验证时的事实记录
  fast           Boolean? // 快决策(当场拍板)/慢决策(深思后定)；null=未标注——快慢准确率分开统计
  disputeNote    String? // WO-11：用户异议（复盘时军师带出确认）
  disputedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([userId, seq])
  @@index([tenantId, userId, status])
  @@index([userId, verifyByDate])
  @@map("decision_log")
}

/// 复盘日志（M2 PR-8）：V6.0 §10 六层复盘的事件账本。对齐率/连续复盘天数一律由服务端
/// 从这些行计算（禁止 AI 现编）。day 层由执行页发起复盘时落一条；同层同日 upsert。
model ReviewLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  casefileId   String?
  layer        String   @default("day") // day | week | month | quarter | year | team
  date         String // YYYY-MM-DD（覆盖的日期；week/month 取发起日）
  ordersTotal  Int      @default(0) // 当日军令总数（day 层快照）
  ordersDone   Int      @default(0) // 已完成军令数
  alignedTotal Int      @default(0) // 对齐主要矛盾的军令数
  alignRate    Int? // 对齐率 %（=alignedTotal/ordersTotal；无军令 = null，不编 0%）
  hasBackfill  Boolean  @default(false) // 当日是否回填了三数
  note         String   @default("") @db.Text
  createdAt    DateTime @default(now())
  metricsJson  Json? // WO-04：week/month 期聚合 { leads, consults, deals }

  @@unique([userId, layer, date])
  @@index([tenantId, userId, layer, date])
  @@map("review_log")
}

/// 预言日志（M2 PR-9）：V6.0 §4.8 天机验证——每条预言带验证标准与到期时间，
/// 命中率一律由服务端统计（禁止 AI 现编）。写入源：真实模型抽取（测试/mock 不产生伪预言）+ 显式记录。
model ProphecyLog {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  seq            Int // 用户内序号（预言 #N）
  prophecy       String    @db.Text // 预言内容（具体、可验证）
  basis          String    @default("") // 依据（八字推演简述）
  verifyStandard String    @default("") @db.Text // 什么情况算命中/未命中
  dueDate        String? // YYYY-MM-DD 预计可验证时间
  status         String    @default("pending") // pending | hit | miss
  verifiedAt     DateTime?
  verifyNote     String    @default("") @db.Text
  dueNotifiedAt  DateTime? // 到期提醒已登记（scheduler 幂等标记）
  disputeNote    String? // WO-11：用户异议（复盘时军师带出确认）
  disputedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@unique([userId, seq])
  @@index([tenantId, userId, status])
  @@index([status, dueDate])
  @@map("prophecy_log")
}

/// 用户进度（M2 PR-10）：战略段位与里程碑。段位按真实门槛派生（连续复盘天数 +
/// 决策准确率 + 天机命中率，V6.0 §11.4），只升不降；里程碑按使用天数解锁（§11.2）。
/// 全部由服务端 syncProgress 计算落库——绝不出现没有数据支撑的「连续 47 天」。
model UserProgress {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String   @unique
  rank           String   @default("新兵") // 新兵 | 尉官 | 校官 | 将军 | 元帅
  rankAchievedAt DateTime @default(now())
  milestonesJson Json // { "7": "2026-07-09", "30": ... } 已解锁里程碑 → 解锁日期
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@map("user_progress")
}

/// V7-12：单次付费商品目录（SKU）。运营可改价（admin:sync-content 幂等 upsert，代码目录即真相源）。
/// kind: module=启用某能力(grantsModuleKey) | service=一次性服务(如深度整理) | storage=空间包。
model Sku {
  id              String   @id @default(cuid())
  key             String   @unique // deep-organize | storage-2g | deep-contradiction | ...
  name            String
  desc            String   @db.Text
  priceFen        Int // 售价（分）
  kind            String   @default("module") // module | service | storage
  grantsModuleKey String? // kind=module 时发放的能力 key（→ UserModule）
  metaJson        Json? // 扩展（storage 加档字节数等）
  enabled         Boolean  @default(true)
  sort            Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@map("sku")
}

/// V7-07：用户数据源绑定状态（真实 OAuth 后置；v1 只做状态持久化 + 上传替代动线）。
/// status: unbound 未绑定 | auth_requested 已预约授权 | uploaded 已上传替代资料 | bound 已绑定。
model UserDataSource {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  sourceKey String // 见 data/dataSources.ts
  status    String   @default("unbound")
  method    String? // upload | oauth
  metaJson  Json? // 关联 knowledgeId / 授权登记信息
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sourceKey])
  @@index([tenantId, userId])
  @@map("user_data_source")
}

/// V7-08：用户能力/模块启用状态。免费模块无需此行即可用；付费模块启用后写一行。
/// source: free 免费直启 | purchase 付费(credits/sku) | admin 后台开通。
model UserModule {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  moduleKey String // 见 data/modules.ts；SKU 一次性服务凭据记为 'sku:'+skuKey
  enabled   Boolean  @default(true)
  hidden    Boolean  @default(false) // 我的页可隐藏
  sortOrder Int      @default(0)
  source    String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleKey])
  @@index([tenantId, userId])
  @@map("user_module")
}

/// V7-13：社群服务分配（运营手工分班/配老师）。每用户至多一行。
model ServiceAssignment {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String   @unique
  teacherName   String   @default("")
  teacherWechat String   @default("")
  className     String   @default("")
  groupQrUrl    String   @default("")
  taskDone      Int      @default(0)
  taskTotal     Int      @default(0)
  note          String   @default("") @db.Text
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@map("service_assignment")
}

/// D-1：开通来源归因事件（轻量事件流，不复用/不污染 UserAgent.source 的 gift|purchase|admin_grant 语义）。
/// 每次「解锁 agent / 购买 SKU 成功」落一条，source 由前端请求体传入（缺省 catalog）；漏斗报表按 source 分组计数。
model ActivationEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  itemType  String // 'agent' | 'sku'
  itemKey   String // agentKey 或 skuKey
  source    String // 'prescription' | 'catalog' | 'market'
  refId     String? // source=prescription 时的 prescriptionId
  createdAt DateTime @default(now())

  @@index([tenantId, itemType, itemKey])
  @@index([source, createdAt])
  @@map("activation_event")
}

/// D-3-7：生态工具注册表（数字人代播/短剧等外部小程序跳转位）。id = toolKey，可开方白名单 = enabled agents ∪ enabled EcoTool。
/// 种子不预置任何行——由运营录入 appId 后 enabled 才可开方。目标小程序须与本小程序同一微信开放平台主体关联方可跳转（见 §13）。
model EcoTool {
  id        String   @id // toolKey，如 'digital-human'
  name      String // 「数字人代播」
  desc      String   @db.Text // 开方场景一句话（供【可开方工具表】注入）
  appId     String   @default("") // 目标小程序 appId
  path      String   @default("") // 目标页面路径（可带占位参数）
  enabled   Boolean  @default(false)
  sort      Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("eco_tool")
}
