# —— 军师后端环境变量（示例，复制为 .env） ——
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/junshi?schema=public"
PORT=4000

# AI 提供方：
#   mock   —— 默认，模板产出，零配置可离线
#   claude —— Anthropic 官方
#   openai —— OpenAI 通用协议（兼容 DeepSeek / Moonshot(Kimi) / 通义千问兼容模式 等）
# 注：当 key 仍是占位/假值（含 fake、replace、xxxx 等）时，自动降级为 mock，
#     不会真正发起网络请求；填入真实 key 后即自动切到真实模型。
AI_PROVIDER=openai

# —— Claude（Anthropic）——
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# —— OpenAI 通用协议 ——
# 先 fake 一个 token；换真实 key 时只改这一行即可。
OPENAI_API_KEY=sk-fake-please-replace-0000000000000000000000000000
# 网关地址（务必带 /v1）：
#   OpenAI   https://api.openai.com/v1
#   DeepSeek https://api.deepseek.com/v1
#   Moonshot https://api.moonshot.cn/v1
#   通义千问  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# 模型名（按所选网关填）：gpt-4o-mini / deepseek-chat / moonshot-v1-8k / qwen-plus ...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=20000

MODERATION_ENABLED=true
