# —— 军师后端环境变量（示例，复制为 .env） ——
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/junshi?schema=public"
PORT=4000

# —— 运营后台鉴权（保护 /api/admin/*）——
# 主密钥 ADMIN_TOKEN：① 首次进入用它初始化管理员账号+密码；② 之后保留为应急/找回通道（登录页「用密钥应急登录」）。
# 日常登录用账号密码（账户表 admin_account，密码 scrypt 哈希）。请求带 x-admin-token / Authorization: Bearer。
# 留空则仅放行后台账户会话 / role='admin' 账号；生产务必设为高强度随机串。请求时读取，可不重启即时轮换。
ADMIN_TOKEN=junshi-admin-dev

# —— 敏感字段加密（模型/Dify/技能库 API Key 等存库前 AES-256-GCM 加密）——
# 留空：不加密，按历史明文存取（演示/本地零配置仍可跑）。
# 配置高强度随机串后：① 新写入的密钥自动加密；② 对存量明文跑一次 `npm run secrets:encrypt` 回填。
# ⚠️ 该密钥一旦用于加密就不可丢失/更改，否则已加密字段无法解密（需重填）。生产建议接 KMS/密管。
APP_ENCRYPTION_KEY=

# —— 用户登录态 JWT（HS256，services/userToken.ts）——
# 留空：登录态沿用历史口径 token=userId（演示/测试免改）。
# 配置后：新登录签发 JWT（带 sub/iat/exp）；历史 userId token 默认仍放行以平滑过渡。
APP_JWT_SECRET=
APP_JWT_TTL_SEC=2592000        # JWT 有效期（秒），默认 30 天
# 置 true 强制只认 JWT（历史 userId token 立即失效，需重新登录）。生产稳定后再开。
APP_JWT_REQUIRED=false

# —— 缓存（services/cache.ts）——
# 留空：进程内内存缓存（演示/单实例）。配 redis:// 且 `npm i ioredis` 后切 Redis（多实例共享、可横向扩展）。
REDIS_URL=

# —— 内容审核（services/moderation.ts）——
MODERATION_ENABLED=true
# keyword：演示关键词表（默认）。http：调外部合规审核服务（需补 MODERATION_API_URL/KEY）。
MODERATION_PROVIDER=keyword
MODERATION_API_URL=
MODERATION_API_KEY=
MODERATION_TIMEOUT_MS=3000
# 审核服务不可达时：true=放行（默认，避免抖动阻断），false=拦截（强合规）。
MODERATION_FAIL_OPEN=true

# —— 微信小程序登录 + 本机号一键登录（server 模式小程序联调用）——
# AppID 可与 app/project.config.json 保持一致；AppSecret 只放服务端，不要下发到小程序。
# 本机号一键登录（getPhoneNumber）复用同一对 AppID/Secret，无需额外配置；
# 但小程序须为「企业/组织」主体并已开通「手机号快速验证」能力，个人主体只能走短信验证码。
WECHAT_MINI_APPID=wx05a49967e2adb557
WECHAT_MINI_SECRET=

# —— 微信支付 v3（小程序 JSAPI 套餐购买，services/wechatPay.ts）——
# 全部配齐才启用真实支付（payConfigured()=true）：此时 /plans/:id/purchase 演示购买被禁用，
# 改走 /plans/:id/order 下单 + /pay/wechat/notify 回调入账；未配齐则继续用演示购买。
WECHAT_PAY_MCHID=
WECHAT_PAY_APIV3_KEY=          # APIv3 密钥（32 位）：回调资源 AEAD 解密用
WECHAT_PAY_CERT_SERIAL=        # 商户证书序列号
WECHAT_PAY_PRIVATE_KEY=        # 商户私钥 PEM（apiclient_key.pem 内容，换行可用字面 \n）
WECHAT_PAY_NOTIFY_URL=         # 支付结果回调地址（公网 https）
# 平台证书 PEM（可选）：配了才做回调签名校验；未配则仅靠 AEAD 解密判真伪。
WECHAT_PAY_PLATFORM_CERT=

# —— 短信验证码登录 ——
# provider=console：开发/演示，不发真短信，验证码打日志并随响应回传（前端自动回填）。
#          aliyun ：阿里云短信，需补全下方 ALIYUN_SMS_*（模板变量名须为 code）。
SMS_PROVIDER=console
# 生产置 true：/auth/login 强制校验验证码（默认 false 以兼容演示/测试免码登录）。
SMS_REQUIRE_CODE=false
# 强制把验证码随响应返回（默认仅 console+非生产时返回；生产+aliyun 切勿开启）。
SMS_RETURN_CODE=false
SMS_CODE_TTL_SEC=300          # 验证码有效期（秒）
SMS_RESEND_COOLDOWN_SEC=60    # 同号两次发送最小间隔（秒）
SMS_MAX_PER_HOUR=5            # 同号每小时发送上限
SMS_MAX_ATTEMPTS=5           # 同一验证码最多校验次数
# 阿里云短信（SMS_PROVIDER=aliyun 时必填）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=SMS_508120103
ALIYUN_SMS_REGION=cn-hangzhou

# ★ 推荐：大模型在「运营后台 → 模型」里可视化配置并随时切换（存数据库，即时生效）。
#   默认 Agnes 2.0 Flash（apihub.agnes-ai.com/v1，OpenAI 兼容）；填入 Key 即切真实模型。
#   下面这些 env 仅作「数据库无配置/不可达」时的兜底。
#
# AI 提供方（兜底）：
#   mock   —— 模板产出，零配置可离线
#   claude —— Anthropic 官方
#   openai —— OpenAI 通用协议（兼容 Agnes / DeepSeek / Moonshot(Kimi) / 通义千问 等）
# 注：当 key 仍是占位/假值（含 fake、replace、xxxx 等）时，自动降级为 mock。
AI_PROVIDER=openai

# —— Claude（Anthropic）——
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# —— OpenAI 通用协议 ——
# 先 fake 一个 token；换真实 key 时只改这一行即可。
OPENAI_API_KEY=sk-fake-please-replace-0000000000000000000000000000
# 网关地址（务必带 /v1）：
#   OpenAI   https://api.openai.com/v1
#   DeepSeek https://api.deepseek.com/v1
#   Moonshot https://api.moonshot.cn/v1
#   通义千问  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# 模型名（按所选网关填）：gpt-4o-mini / deepseek-chat / moonshot-v1-8k / qwen-plus ...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=20000

# —— 知识库 / 语义记忆 的嵌入模型 ——
# 留空 = 用本地确定性嵌入（零依赖、离线，EMBED_DIM=256）；
# 填模型名 + 上面 openai 兼容真实 key，则走 /embeddings 真实向量（生产建议配合 pgvector）。
# 例：text-embedding-3-small（OpenAI）/ text-embedding-v3（通义）/ embedding-2（智谱）...
EMBEDDING_MODEL=

# 知识/记忆向量近邻检索：默认 false 走内存余弦（零依赖）。
# 置 true 前需先执行 `npm run db:pgvector`（建 vector 列 + HNSW 索引），否则检索会回退内存。
PGVECTOR_ENABLED=false

MODERATION_ENABLED=true
