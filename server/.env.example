# —— 军师后端环境变量（示例，复制为 .env） ——
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/junshi?schema=public"
PORT=4000

# —— 微信小程序登录（server 模式小程序联调用）——
# AppID 可与 app/project.config.json 保持一致；AppSecret 只放服务端，不要下发到小程序。
WECHAT_MINI_APPID=wx05a49967e2adb557
WECHAT_MINI_SECRET=

# ★ 推荐：大模型在「运营后台 → 模型」里可视化配置并随时切换（存数据库，即时生效）。
#   默认 Agnes 2.0 Flash（apihub.agnes-ai.com/v1，OpenAI 兼容）；填入 Key 即切真实模型。
#   下面这些 env 仅作「数据库无配置/不可达」时的兜底。
#
# AI 提供方（兜底）：
#   mock   —— 模板产出，零配置可离线
#   claude —— Anthropic 官方
#   openai —— OpenAI 通用协议（兼容 Agnes / DeepSeek / Moonshot(Kimi) / 通义千问 等）
# 注：当 key 仍是占位/假值（含 fake、replace、xxxx 等）时，自动降级为 mock。
AI_PROVIDER=openai

# —— Claude（Anthropic）——
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# —— OpenAI 通用协议 ——
# 先 fake 一个 token；换真实 key 时只改这一行即可。
OPENAI_API_KEY=sk-fake-please-replace-0000000000000000000000000000
# 网关地址（务必带 /v1）：
#   OpenAI   https://api.openai.com/v1
#   DeepSeek https://api.deepseek.com/v1
#   Moonshot https://api.moonshot.cn/v1
#   通义千问  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# 模型名（按所选网关填）：gpt-4o-mini / deepseek-chat / moonshot-v1-8k / qwen-plus ...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=20000

# —— 知识库 / 语义记忆 的嵌入模型 ——
# 留空 = 用本地确定性嵌入（零依赖、离线，EMBED_DIM=256）；
# 填模型名 + 上面 openai 兼容真实 key，则走 /embeddings 真实向量（生产建议配合 pgvector）。
# 例：text-embedding-3-small（OpenAI）/ text-embedding-v3（通义）/ embedding-2（智谱）...
EMBEDDING_MODEL=

# 知识/记忆向量近邻检索：默认 false 走内存余弦（零依赖）。
# 置 true 前需先执行 `npm run db:pgvector`（建 vector 列 + HNSW 索引），否则检索会回退内存。
PGVECTOR_ENABLED=false

MODERATION_ENABLED=true
