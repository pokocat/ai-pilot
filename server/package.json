{
  "name": "junshi-server",
  "version": "0.1.0",
  "private": true,
  "description": "军师 · AI 商业军师 — 后端 API（LLM Gateway / 会话 / 记忆 / 成果库 / 运营配置）",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-plans": "tsx scripts/syncPlans.ts",
    "db:bump-free-quota": "tsx scripts/bumpFreeQuota.ts",
    "pay:e2e": "tsx scripts/pay-e2e.ts",
    "pay:mock": "tsx scripts/wechat-pay-mock.ts",
    "pay:e2e:mock": "tsx scripts/pay-mock-e2e.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:pgvector": "psql \"$DATABASE_URL\" -f prisma/pgvector.sql",
    "admin:sync-content": "tsx scripts/syncAdminContent.ts",
    "db:reembed": "tsx scripts/reembed.ts",
    "secrets:encrypt": "tsx scripts/encryptSecrets.ts",
    "pretest": "node --env-file=.env.test node_modules/prisma/build/index.js db push --skip-generate",
    "test": "node --env-file=.env.test --import tsx --test --test-concurrency=1 test/*.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "ali-oss": "^6.21.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "iztro": "^2.5.8",
    "lunar-typescript": "^1.8.6",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1"
  }
}
